# =========================================================
# HealthFlow — Environment Variables
# Copy this file to .env.local and fill in your values.
# All integrations are optional — the app works with mocks.
# =========================================================

# ---------------------------------------------------------
# AI / LLM (pick one or both; Gemini takes priority if set)
# ---------------------------------------------------------

# Anthropic Claude — for agent reasoning, diagnosis, structuring
# Get key: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=

# Google Gemini — alternative LLM (overrides Anthropic when set)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ---------------------------------------------------------
# Voice Transcription
# ---------------------------------------------------------

# ElevenLabs Scribe — for paramedic voice capture
# Get key: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# ---------------------------------------------------------
# Cross-app API routing (monorepo)
# ---------------------------------------------------------

# URL of the API service that all frontend apps talk to.
# Default: http://localhost:3001 (local dev)
# In production: set to your deployed API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# ---------------------------------------------------------
# Database — Production persistence (optional)
# Without these, the app uses an in-memory store that resets
# on each server restart. Fine for demos; not for production.
# Get values: Supabase → Project → Settings → API
# ---------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------

# Apify — live drug interaction data (falls back to built-in DB without this)
# Get token: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Entire.io — external immutable audit trail (falls back to SHA-256 chain without this)
ENTIRE_API_KEY=

# Scalekit — production auth (demo tokens used without this)
SCALEKIT_ENV_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
