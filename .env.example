# Supabase (optional — app works with in-memory store by default)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (optional — agents use rule-based logic by default)
ANTHROPIC_API_KEY=your-anthropic-key

# Scalekit (optional — using demo auth by default)
SCALEKIT_ENV_URL=https://your-env.scalekit.com
SCALEKIT_CLIENT_ID=your-client-id
SCALEKIT_CLIENT_SECRET=your-client-secret

# Apify (optional — using mock drug interaction DB by default)
APIFY_API_TOKEN=your-apify-token

# ElevenLabs Speech-to-Text
ELEVENLABS_API_KEY=your-elevenlabs-key

# Entire.io (optional — using local audit log by default)
ENTIRE_API_KEY=your-entire-key
